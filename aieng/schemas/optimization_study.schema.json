{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/optimization_study.schema.json",
  "title": ".aieng optimization study envelope",
  "description": "Agent-guided optimization-study configuration. Links to the existing design-study problem rather than replacing it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schema_version", "study_id", "design_study_problem_ref", "algorithm", "sampling", "budget", "status", "artifact_refs", "candidate_ids", "provenance", "claim_policy"],
  "properties": {
    "format": {"const": "aieng.optimization_study"},
    "schema_version": {"const": "0.1"},
    "study_id": {"type": "string", "minLength": 1},
    "design_study_problem_ref": {"const": "analysis/design_study_problem.json"},
    "design_study_problem_id": {"type": ["string", "null"]},
    "algorithm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "phase", "bounded_step"],
      "properties": {
        "name": {"enum": ["grid", "random", "latin_hypercube", "manual", "slsqp", "bayesian", "genetic"]},
        "phase": {"type": "integer", "minimum": 1, "maximum": 5},
        "bounded_step": {"const": true},
        "seed": {"type": ["integer", "null"]},
        "settings": {"type": "object"}
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_candidate_count", "max_candidate_count"],
      "properties": {
        "requested_candidate_count": {"type": "integer", "minimum": 1},
        "max_candidate_count": {"type": "integer", "minimum": 1},
        "include_baseline": {"type": "boolean"},
        "seed": {"type": ["integer", "null"]}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_candidates", "max_iterations"],
      "properties": {
        "max_candidates": {"type": "integer", "minimum": 1},
        "max_iterations": {"type": "integer", "minimum": 1},
        "max_solver_runs": {"type": ["integer", "null"], "minimum": 0},
        "max_wall_time_seconds": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "convergence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional Phase-2 iterative-loop stopping thresholds. Omitted fields use documented defaults.",
      "properties": {
        "min_rel_improvement": {"type": "number", "exclusiveMinimum": 0, "description": "Relative objective gain below which an iteration counts as no-progress."},
        "patience": {"type": "integer", "minimum": 1, "description": "Consecutive no-progress iterations before declaring convergence."},
        "feasible_patience": {"type": "integer", "minimum": 1, "description": "Iterations allowed with no feasible incumbent before asking the user."},
        "max_consecutive_failures": {"type": "integer", "minimum": 1, "description": "Consecutive all-failed rounds before giving up."}
      }
    },
    "status": {"enum": ["draft", "defined", "sampling", "evaluating", "ranked", "accepted", "completed", "failed", "cancelled"]},
    "artifact_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variables", "objectives", "constraints", "decision_log"],
      "properties": {
        "variables": {"const": "analysis/optimization_variables.json"},
        "objectives": {"const": "analysis/optimization_objectives.json"},
        "constraints": {"const": "analysis/optimization_constraints.json"},
        "decision_log": {"const": "analysis/optimization_decision_log.json"},
        "iterations": {"const": "analysis/design_study_iterations.json"},
        "ranking": {"const": "analysis/design_study_candidate_ranking.json"},
        "acceptance": {"const": "analysis/design_study_acceptance.json"}
      }
    },
    "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "provenance": {"$ref": "#/$defs/provenance"},
    "claim_policy": {"$ref": "#/$defs/claim_policy"}
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by", "claim_advancement"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "audit_event_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "claim_advancement": {"const": "none"}
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advisory_only", "baseline_unchanged", "human_approval_required_for_acceptance", "claim_advancement"],
      "properties": {
        "advisory_only": {"const": true},
        "baseline_unchanged": {"const": true},
        "human_approval_required_for_acceptance": {"const": true},
        "claim_advancement": {"const": "none"}
      }
    }
  }
}
