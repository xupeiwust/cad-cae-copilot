{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/design_target_comparison.schema.json",
  "title": "Design target comparison block",
  "description": "Embedded inside result_summary.json. Compares explicit design targets against actual evidence. Does not constitute engineering certification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["present", "summary", "items"],
  "properties": {
    "present": {"type": "boolean"},
    "target_set_id": {"type": "string", "minLength": 1},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "pass", "fail", "unknown", "not_evaluated"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "pass": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0},
        "unknown": {"type": "integer", "minimum": 0},
        "not_evaluated": {"type": "integer", "minimum": 0}
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_id", "target_type", "expected", "actual", "comparator", "status"],
        "properties": {
          "target_id": {"type": "string", "minLength": 1},
          "target_type": {
            "type": "string",
            "enum": [
              "mass_reduction_target",
              "absolute_mass_target",
              "minimum_safety_factor",
              "maximum_von_mises_stress",
              "maximum_displacement",
              "preserved_interface",
              "objective_priority"
            ]
          },
          "expected": {
            "type": "object",
            "properties": {
              "comparator": {"type": "string"},
              "threshold": {"type": "number"},
              "threshold_min": {"type": "number"},
              "threshold_max": {"type": "number"},
              "objective_order": {"type": "array", "items": {"type": "string"}}
            }
          },
          "actual": {
            "type": "object",
            "properties": {
              "value": {},
              "unit": {"type": ["string", "null"]},
              "source_artifact": {"type": "string"}
            }
          },
          "comparator": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "unknown", "not_evaluated"]
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "source_artifacts": {
            "type": "array",
            "items": {"type": "string"}
          },
          "notes": {"type": "string"}
        }
      }
    }
  }
}
