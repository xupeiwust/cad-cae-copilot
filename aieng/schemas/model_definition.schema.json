{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/model_definition.schema.json",
  "title": ".aieng model definition input",
  "type": "object",
  "required": [
    "model_id",
    "label",
    "description",
    "features",
    "constraints",
    "material",
    "coordinate_system"
  ],
  "properties": {
    "model_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "required": [
        "source",
        "authoring_method"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "authoring_method": {
          "type": "string",
          "minLength": 1
        },
        "material_data_source": {
          "type": "string",
          "minLength": 1
        },
        "parameter_basis": {
          "type": "string",
          "minLength": 1
        },
        "created_for": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "design_requirements": {
      "type": "object",
      "additionalProperties": true
    },
    "manufacturing": {
      "type": "object",
      "required": [
        "process"
      ],
      "properties": {
        "process": {
          "type": "string",
          "minLength": 1
        },
        "stock_material_form": {
          "type": "string",
          "minLength": 1
        },
        "minimum_wall_thickness_mm": {
          "type": "number"
        },
        "minimum_hole_edge_distance_mm": {
          "type": "number"
        },
        "preferred_internal_corner_radius_mm": {
          "type": "number"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "simulation": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "static_structural"
        },
        "fixed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "loads": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "target",
              "type",
              "value_n",
              "direction"
            ],
            "properties": {
              "target": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "value_n": {
                "type": "number"
              },
              "direction": {
                "$ref": "#/$defs/vector3"
              },
              "application": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        },
        "requested_outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "feature_id",
          "type",
          "name",
          "parameters"
        ],
        "properties": {
          "feature_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "base_plate",
              "mounting_hole",
              "mounting_hole_pattern",
              "rib",
              "fillet",
              "chamfer",
              "boss",
              "flange",
              "interface_face",
              "unknown_feature"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "geometry_refs": {
            "type": "object",
            "properties": {
              "faces": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "edges": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "entities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "parameters": {
            "type": "object"
          },
          "intent": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "source_feature_id": {
                  "type": "string",
                  "minLength": 1
                },
                "target_feature_id": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "target",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "protect_geometry",
              "protect_position",
              "protect_dimension",
              "min_value",
              "max_value",
              "preserve_interface",
              "manufacturing_rule",
              "simulation_target"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "parameter": {
            "type": "string"
          },
          "value": {},
          "metric": {
            "type": "string"
          },
          "operator": {
            "enum": [
              "<",
              "<=",
              ">",
              ">=",
              "=",
              "=="
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "material": {
      "type": "object",
      "required": [
        "name",
        "properties"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
          "source": {
            "type": "string",
            "minLength": 1
          },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "additionalProperties": false
    },
    "coordinate_system": {
      "type": "object",
      "required": [
        "type",
        "handedness",
        "units",
        "origin",
        "axes"
      ],
      "properties": {
        "type": {
          "const": "cartesian"
        },
        "handedness": {
          "enum": [
            "right",
            "left"
          ]
        },
        "units": {
          "type": "object",
          "required": [
            "length"
          ],
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "origin": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        },
        "axes": {
          "type": "object",
          "required": [
            "x",
            "y",
            "z"
          ],
          "properties": {
            "x": {
              "$ref": "#/$defs/vector3"
            },
            "y": {
              "$ref": "#/$defs/vector3"
            },
            "z": {
              "$ref": "#/$defs/vector3"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    }
  }
}
