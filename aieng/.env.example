# Copy this file to `.env` and fill in the values you need.

# Common benchmark defaults
BENCHMARK_PROVIDER=anthropic
BENCHMARK_MODEL=claude-3-7-sonnet-latest

# For OpenAI-compatible providers only
BENCHMARK_BASE_URL=https://your-openai-compatible-endpoint.example/v1

# Optional generic API key variable used by the benchmark runner
BENCHMARK_API_KEY=

# Provider-specific API keys (preferred when you switch providers often)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional override if you want the runner to read the API key from another env var name
# BENCHMARK_API_KEY_ENV=MY_CUSTOM_API_KEY
