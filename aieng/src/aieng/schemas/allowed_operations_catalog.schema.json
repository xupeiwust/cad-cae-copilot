{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/allowed_operations_catalog.schema.json",
  "title": ".aieng allowed operations catalog",
  "type": "object",
  "required": [
    "format_version",
    "catalog_id",
    "generated_by",
    "generated_at_utc",
    "source_files",
    "feature_operations",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "catalog_id": {"type": "string", "minLength": 1},
    "generated_by": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "source_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "feature_operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature_id", "feature_type", "protected", "interface_roles", "operations"],
        "additionalProperties": false,
        "properties": {
          "feature_id": {"type": "string", "minLength": 1},
          "feature_type": {"type": "string", "minLength": 1},
          "protected": {"type": "boolean"},
          "interface_roles": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "operations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "operation_type",
                "status",
                "reason",
                "preconditions",
                "blocked_by_constraints"
              ],
              "additionalProperties": false,
              "properties": {
                "operation_type": {
                  "type": "string",
                  "enum": [
                    "modify_parameter",
                    "add_feature",
                    "remove_feature",
                    "protect_feature",
                    "assign_material",
                    "assign_boundary_condition",
                    "assign_load"
                  ]
                },
                "status": {
                  "type": "string",
                  "enum": ["allowed", "forbidden", "conditional"]
                },
                "reason": {"type": "string", "minLength": 1},
                "preconditions": {
                  "type": "array",
                  "items": {"type": "string", "minLength": 1}
                },
                "blocked_by_constraints": {
                  "type": "array",
                  "items": {"type": "string", "minLength": 1}
                }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$comment": "Phase 19 C3 generated operation-admissibility catalog for AI patch planning."
}
