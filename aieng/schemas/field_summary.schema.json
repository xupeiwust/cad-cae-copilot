{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/field_summary.schema.json",
  "title": ".aieng field summary",
  "description": "LLM-facing summary of high-magnitude field regions. Observational only; no physical correctness claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary_type",
    "source",
    "status",
    "clusters",
    "llm_summary",
    "claim_policy"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "summary_type": {"type": "string", "const": "cae_field_regions"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_regions_path", "source_frd", "field", "metric"],
      "properties": {
        "field_regions_path": {"type": "string", "minLength": 1},
        "source_frd": {"type": "string"},
        "field": {"type": "string"},
        "metric": {"type": "string"}
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["has_field_regions", "cluster_count", "warnings"],
      "properties": {
        "has_field_regions": {"type": "boolean"},
        "cluster_count": {"type": "integer", "minimum": 0},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    },
    "clusters": {"type": "array", "items": {"type": "object"}},
    "llm_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["one_line", "key_findings", "risks", "limitations"],
      "properties": {
        "one_line": {"type": "string"},
        "key_findings": {"type": "array", "items": {"type": "string"}},
        "risks": {"type": "array", "items": {"type": "string"}},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "targets_status": {
          "type": "array",
          "description": "Optional reference to design-target compliance state pulled verbatim from result_summary.targets[*].met. Does not re-assert physical correctness; surfaces 'what the solver-derived result_summary already says' so the LLM can decide next steps.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "metric", "met"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "metric": {"type": ["string", "null"]},
              "met": {
                "description": "Compliance state pulled from result_summary; boolean true/false or the literal 'unknown' when evidence is absent.",
                "oneOf": [
                  {"type": "boolean"},
                  {"type": "string", "const": "unknown"}
                ]
              },
              "source": {
                "type": ["string", "null"],
                "description": "Origin of the underlying computed metric; copied from result_summary."
              }
            }
          }
        }
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observational_only",
        "physical_correctness_not_claimed",
        "full_field_not_serialized"
      ],
      "properties": {
        "observational_only": {"type": "boolean", "const": true},
        "physical_correctness_not_claimed": {"type": "boolean", "const": true},
        "full_field_not_serialized": {"type": "boolean", "const": true}
      }
    }
  }
}
