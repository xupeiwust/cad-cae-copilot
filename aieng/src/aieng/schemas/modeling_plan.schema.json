{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/modeling_plan.schema.json",
  "title": "ModelingPlan",
  "description": "Kernel-agnostic CAD operation IR for Phase 1. Primitive-first: only create_box and create_cylindrical_cut are allowed.",
  "type": "object",
  "required": ["plan_id", "plan_schema_version", "intent", "units", "steps"],
  "additionalProperties": false,
  "properties": {
    "plan_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this modeling plan."
    },
    "plan_schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Version of the modeling plan schema. Independent from .aieng FORMAT_VERSION."
    },
    "intent": {
      "type": "object",
      "required": ["original_text"],
      "additionalProperties": false,
      "properties": {
        "original_text": {
          "type": "string",
          "minLength": 1,
          "description": "Original natural language input from the user."
        },
        "interpreted_goal": {
          "type": "string",
          "description": "Normalized interpretation of the user's intent."
        }
      }
    },
    "units": {
      "type": "object",
      "required": ["length", "angle"],
      "additionalProperties": false,
      "properties": {
        "length": {
          "enum": ["mm", "cm", "m", "in"],
          "description": "Unit of length used in this plan."
        },
        "angle": {
          "enum": ["deg", "rad"],
          "description": "Unit of angle used in this plan."
        }
      }
    },
    "assumptions": {
      "type": "array",
      "description": "Explicit assumptions made by the planner.",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string"
          },
          "requires_user_confirmation": {
            "type": "boolean"
          }
        }
      }
    },
    "missing_information": {
      "type": "array",
      "description": "Information the planner determined was missing from the input.",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": ["info", "warning", "blocking"]
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of primitive modeling operations.",
      "items": {
        "type": "object",
        "required": ["step_id", "operation", "parameters"],
        "additionalProperties": false,
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^step_[0-9]{3}$",
            "description": "Unique step identifier, e.g. step_001."
          },
          "operation": {
            "enum": ["create_box", "create_cylindrical_cut"],
            "description": "Primitive operation. Family operations like create_plate are prohibited."
          },
          "creates": {
            "type": "string",
            "minLength": 1,
            "description": "Unique identifier for the body created by this step."
          },
          "target": {
            "type": "string",
            "description": "step_id of the target body for cut operations. Must refer to a prior step."
          },
          "parameters": {
            "type": "object",
            "description": "Operation-specific parameters. Validated via conditional schema."
          },
          "rationale": {
            "type": "string",
            "description": "Human-readable rationale for this step."
          },
          "assumption_refs": {
            "type": "array",
            "description": "References to assumption IDs used by this step.",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "confidence": {
            "enum": ["certain", "inferred", "guessed"],
            "description": "Confidence level of the planner's interpretation for this step."
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "operation": {
                  "const": "create_box"
                }
              }
            },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "#/$defs/CreateBoxParameters"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "operation": {
                  "const": "create_cylindrical_cut"
                }
              }
            },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "#/$defs/CreateCylindricalCutParameters"
                }
              }
            }
          }
        ]
      }
    },
    "checks": {
      "type": "array",
      "description": "Post-execution checks to validate the modeling result.",
      "items": {
        "type": "object",
        "required": ["check_type"],
        "additionalProperties": false,
        "properties": {
          "check_type": {
            "enum": ["bounding_box", "operation_count"]
          },
          "parameters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "expected_size": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "number"
                }
              },
              "tolerance": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "origin_mode": {
                "enum": ["corner", "center"]
              },
              "by_operation": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "check_type": {
                  "const": "bounding_box"
                }
              }
            },
            "then": {
              "properties": {
                "parameters": {
                  "required": ["expected_size", "tolerance"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "check_type": {
                  "const": "operation_count"
                }
              }
            },
            "then": {
              "properties": {
                "parameters": {
                  "required": ["by_operation"]
                }
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "CreateBoxParameters": {
      "type": "object",
      "required": ["length", "width", "height"],
      "additionalProperties": false,
      "description": "Parameters for create_box primitive. Origin is the minimum corner by default.",
      "properties": {
        "length": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "origin": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          },
          "description": "Origin coordinates [x, y, z]. Interpretation depends on origin_mode."
        },
        "origin_mode": {
          "enum": ["corner", "center"],
          "default": "corner",
          "description": "corner = minimum corner (Phase 1 default); center = geometric center."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "FreeCAD object name for the created box."
        }
      }
    },
    "CreateCylindricalCutParameters": {
      "type": "object",
      "required": ["radius", "depth", "position"],
      "additionalProperties": false,
      "description": "Parameters for create_cylindrical_cut primitive. Target is specified at the step level, not here.",
      "properties": {
        "radius": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "depth": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "position": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          },
          "description": "Cylinder base center [x, y, z]."
        },
        "axis": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          },
          "description": "Cylinder axis direction vector. Defaults to [0, 0, 1]."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "FreeCAD object name for the cut feature."
        }
      }
    }
  }
}
