{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/evidence_report.schema.json",
  "title": ".aieng consolidated evidence report",
  "description": "Derived validation-state read view generated from validation/status.yaml and results/evidence_index.json.",
  "type": "object",
  "required": [
    "format_version",
    "report_id",
    "model_id",
    "generated_at_utc",
    "source_files",
    "derived_view_policy",
    "claim_status_counts",
    "claims",
    "validation_state_snapshot",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "report_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "source_files": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string", "minLength": 1}
    },
    "derived_view_policy": {
      "type": "object",
      "required": [
        "is_derived_view",
        "source_of_truth_is_elsewhere",
        "authoritative_sources",
        "no_claim_auto_advance"
      ],
      "additionalProperties": false,
      "properties": {
        "is_derived_view": {"type": "boolean", "const": true},
        "source_of_truth_is_elsewhere": {"type": "boolean", "const": true},
        "authoritative_sources": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "minLength": 1}
        },
        "no_claim_auto_advance": {"type": "boolean", "const": true}
      }
    },
    "claim_status_counts": {
      "type": "object",
      "required": ["pass", "fail", "unsupported", "partially_supported", "needs_review"],
      "additionalProperties": false,
      "properties": {
        "pass": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0},
        "unsupported": {"type": "integer", "minimum": 0},
        "partially_supported": {"type": "integer", "minimum": 0},
        "needs_review": {"type": "integer", "minimum": 0}
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "claim_type",
          "claim_text",
          "verification_status",
          "required_evidence_ids",
          "actual_evidence_ids",
          "missing_required_evidence_ids",
          "linked_evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "claim_type": {"type": "string", "minLength": 1},
          "claim_text": {"type": "string", "minLength": 1},
          "verification_status": {"type": "string", "minLength": 1},
          "required_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "actual_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "missing_required_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "linked_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["evidence_id"],
              "additionalProperties": false,
              "properties": {
                "evidence_id": {"type": "string", "minLength": 1},
                "status": {"type": "string", "minLength": 1},
                "evidence_type": {"type": "string", "minLength": 1},
                "artifact_path": {"type": "string", "minLength": 1},
                "producer_kind": {"type": "string", "minLength": 1},
                "verification_status": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "validation_state_snapshot": {
      "type": "object",
      "required": [
        "solver_execution",
        "mesh_generation",
        "patch_execution",
        "forbidden_claims_count"
      ],
      "additionalProperties": false,
      "properties": {
        "solver_execution": {"type": "string", "minLength": 1},
        "mesh_generation": {"type": "string", "minLength": 1},
        "patch_execution": {"type": "string", "minLength": 1},
        "forbidden_claims_count": {"type": "integer", "minimum": 0}
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$comment": "Phase 19 C4 consolidated validation-state read view. Source resources remain authoritative."
}
