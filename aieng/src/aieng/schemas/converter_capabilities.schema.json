{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/converter_capabilities.schema.json",
  "title": "CAD/CAE-to-.aieng converter capability profile",
  "description": "Static, source-agnostic declaration of what a CAD/CAE-to-.aieng converter implementation can do. This profile describes the converter itself; per-conversion outcomes are recorded in provenance/conversion_manifest.json.",
  "type": "object",
  "required": [
    "format_version",
    "converter_id",
    "source_system",
    "supported_levels",
    "claim_policy",
    "generated_at_utc"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "converter_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this converter implementation (e.g. 'freecad_reference')."
    },
    "display_name": {"type": "string"},
    "converter_version": {"type": "string"},
    "source_system": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the CAD/CAE source system the converter reads (e.g. 'FreeCAD', 'NX', 'Onshape', 'STEP')."
    },
    "source_file_extensions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "supported_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "name", "supported"],
        "additionalProperties": false,
        "properties": {
          "level": {"type": "integer", "enum": [0, 1, 2, 3, 4, 5]},
          "name": {
            "type": "string",
            "enum": [
              "source_metadata",
              "geometry_topology",
              "object_registry",
              "feature_aware",
              "editability_metadata",
              "roundtrip_writeback_metadata"
            ]
          },
          "supported": {"type": "boolean"},
          "conditional_requirements": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "description": "Optional preconditions (e.g. 'FreeCAD runtime importable', 'OCP/CadQuery installed')."
          },
          "notes": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "claim_policy": {"$ref": "#/$defs/ClaimPolicy"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "ClaimPolicy": {
      "type": "object",
      "required": [
        "best_effort_conversion",
        "missingness_explicit",
        "do_not_infer_missing_information",
        "unsupported_is_not_false",
        "external_tools_execute",
        "aieng_core_executes_external_tools",
        "aieng_core_executes_solvers_meshers_or_optimizers",
        "aieng_core_performs_cad_edits"
      ],
      "additionalProperties": false,
      "properties": {
        "best_effort_conversion": {"type": "boolean", "const": true},
        "missingness_explicit": {"type": "boolean", "const": true},
        "do_not_infer_missing_information": {"type": "boolean", "const": true},
        "unsupported_is_not_false": {"type": "boolean", "const": true},
        "external_tools_execute": {"type": "boolean", "const": true},
        "aieng_core_executes_external_tools": {"type": "boolean", "const": false},
        "aieng_core_executes_solvers_meshers_or_optimizers": {"type": "boolean", "const": false},
        "aieng_core_performs_cad_edits": {"type": "boolean", "const": false}
      }
    }
  },
  "$comment": "Phase 20: declares what a converter implementation is capable of, independent of any single source file. The per-conversion record lives in provenance/conversion_manifest.json."
}
