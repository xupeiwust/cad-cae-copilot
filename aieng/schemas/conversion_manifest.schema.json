{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/conversion_manifest.schema.json",
  "title": "CAD/CAE-to-.aieng per-package conversion manifest",
  "description": "Per-conversion record written to provenance/conversion_manifest.json. Records which converter ran, the source artifact metadata, declared and achieved capability levels, emitted resources, unsupported/missing items, uncertainty notes, and provenance.",
  "type": "object",
  "required": [
    "format_version",
    "manifest_id",
    "generated_at_utc",
    "converter",
    "source",
    "coverage_categories",
    "emitted_resources",
    "unsupported_or_missing",
    "uncertainty_notes",
    "claim_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "manifest_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this conversion manifest entry (e.g. 'conversion_001')."
    },
    "generated_at_utc": {"type": "string", "minLength": 1},
    "converter": {
      "type": "object",
      "required": ["converter_id", "source_system"],
      "additionalProperties": false,
      "properties": {
        "converter_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string"},
        "converter_version": {"type": "string"},
        "source_system": {"type": "string", "minLength": 1},
        "runtime_mode": {
          "type": "string",
          "enum": ["offline", "runtime", "unknown"],
          "description": "Whether the converter ran against the live source-tool runtime API (e.g. FreeCAD imported) or in offline mode parsing the source file directly."
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["filename", "byte_size"],
      "additionalProperties": false,
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "byte_size": {"type": "integer", "minimum": 0},
        "content_sha256": {"type": "string", "minLength": 1},
        "source_system": {"type": "string"},
        "source_document_metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Free-form structured metadata from the source document (e.g. FreeCAD schema version, program version). Should reflect only what the source actually exposed."
        }
      }
    },
    "coverage_categories": {
      "type": "array",
      "description": "Per-category adaptive record of what this specific conversion run captured, inferred, or could not extract. This is the primary interface; declared/achieved capability levels are retained as optional shorthand.",
      "items": {
        "type": "object",
        "required": ["category", "status"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "geometry",
              "topology",
              "object_registry",
              "stable_references",
              "features",
              "parameters",
              "assemblies",
              "materials",
              "loads",
              "boundary_conditions",
              "mesh",
              "solver_deck",
              "cad_cae_mappings",
              "editability_metadata",
              "writeback_metadata"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["complete", "partial", "inferred", "missing", "unsupported", "unavailable_in_source", "unknown"]
          },
          "resources_emitted": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Package-relative paths of resources emitted for this category."
          },
          "missing_items": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Specific items within this category that could not be extracted."
          },
          "inferred_items": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Items within this category that were inferred (heuristic, not confirmed)."
          },
          "notes": {
            "type": "string",
            "description": "Human-readable notes about coverage status for this category."
          }
        }
      }
    },
    "declared_capability_levels": {
      "type": "array",
      "items": {"$ref": "#/$defs/CapabilityLevel"},
      "description": "Optional shorthand: levels the converter declares it can support in general for this source class."
    },
    "achieved_capability_levels": {
      "type": "array",
      "items": {"$ref": "#/$defs/CapabilityLevel"},
      "description": "Optional shorthand: levels actually achieved for THIS conversion, given what the source contained."
    },
    "emitted_resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "kind": {
            "type": "string",
            "enum": [
              "manifest",
              "geometry",
              "topology",
              "feature_graph",
              "object_registry",
              "interface_graph",
              "constraints",
              "protected_regions",
              "simulation_setup",
              "allowed_operations_catalog",
              "completeness_report",
              "validation_status",
              "ai_summary",
              "conversion_manifest"
            ]
          },
          "level": {"type": "integer", "enum": [0, 1, 2, 3, 4, 5]},
          "notes": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "unsupported_or_missing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "status", "description"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "geometry",
              "topology",
              "object_registry",
              "stable_references",
              "features",
              "parameters",
              "assemblies",
              "materials",
              "loads",
              "boundary_conditions",
              "mesh",
              "solver_deck",
              "cad_cae_mappings",
              "editability_metadata",
              "writeback_metadata",
              "editability",
              "simulation_setup",
              "protected_regions",
              "named_selections",
              "pmi_mbd",
              "writeback_strategy",
              "other"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["missing", "unknown", "partial", "unsupported", "conflicting", "not_applicable", "unavailable_in_source", "inferred", "complete"]
          },
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "uncertainty_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "description"],
        "additionalProperties": false,
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "naming_heuristic",
              "feature_candidate",
              "parameter_recovery",
              "topology_extraction",
              "writeback_strategy",
              "source_metadata",
              "other"
            ]
          },
          "description": {"type": "string", "minLength": 1},
          "affected_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "claim_policy": {"$ref": "#/$defs/ClaimPolicy"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "CapabilityLevel": {
      "type": "object",
      "required": ["level", "name"],
      "additionalProperties": false,
      "properties": {
        "level": {"type": "integer", "enum": [0, 1, 2, 3, 4, 5]},
        "name": {
          "type": "string",
          "enum": [
            "source_metadata",
            "geometry_topology",
            "object_registry",
            "feature_aware",
            "editability_metadata",
            "roundtrip_writeback_metadata"
          ]
        },
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "ClaimPolicy": {
      "type": "object",
      "required": [
        "best_effort_conversion",
        "missingness_explicit",
        "do_not_infer_missing_information",
        "unsupported_is_not_false",
        "external_tools_execute",
        "aieng_core_executes_external_tools",
        "aieng_core_executes_solvers_meshers_or_optimizers",
        "aieng_core_performs_cad_edits"
      ],
      "additionalProperties": false,
      "properties": {
        "best_effort_conversion": {"type": "boolean", "const": true},
        "missingness_explicit": {"type": "boolean", "const": true},
        "do_not_infer_missing_information": {"type": "boolean", "const": true},
        "unsupported_is_not_false": {"type": "boolean", "const": true},
        "external_tools_execute": {"type": "boolean", "const": true},
        "aieng_core_executes_external_tools": {"type": "boolean", "const": false},
        "aieng_core_executes_solvers_meshers_or_optimizers": {"type": "boolean", "const": false},
        "aieng_core_performs_cad_edits": {"type": "boolean", "const": false}
      }
    }
  },
  "$comment": "Phase 20: per-conversion record. The static converter profile (independent of any one source) is in converter_capabilities.schema.json."
}
