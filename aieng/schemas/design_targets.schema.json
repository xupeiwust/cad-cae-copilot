{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/design_targets.schema.json",
  "title": ".aieng design targets",
  "description": "Task/design target resource used to compare imported evidence against explicit engineering goals. Targets do not validate physical correctness by themselves.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "targets", "claim_policy"],
  "properties": {
    "format_version": {
      "type": "string",
      "enum": ["0.1.0", "0.1.1"]
    },
    "target_set_id": {"type": "string", "minLength": 1},
    "source_task_id": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"},
        "source_document": {"type": "string"},
        "rationale": {"type": "string"}
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "metric", "operator", "value"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "metric": {
            "type": "string",
            "enum": [
              "mass_reduction_percent",
              "total_mass",
              "minimum_safety_factor",
              "max_von_mises_stress",
              "max_displacement",
              "preserved_interface",
              "objective_priority"
            ]
          },
          "operator": {
            "type": "string",
            "enum": ["<=", "<", ">=", ">", "==", "within_range", "preserve", "reduce_by_at_least", "priority"]
          },
          "value": {"type": "number"},
          "unit": {"type": ["string", "null"]},
          "source": {"type": "string"},
          "notes": {"type": "string"},
          "target_id": {"type": "string", "minLength": 1},
          "target_type": {
            "type": "string",
            "enum": [
              "mass_reduction_target",
              "absolute_mass_target",
              "minimum_safety_factor",
              "maximum_von_mises_stress",
              "maximum_displacement",
              "preserved_interface",
              "objective_priority"
            ]
          },
          "description": {"type": "string", "minLength": 1},
          "comparator": {
            "type": "string",
            "enum": ["<=", "<", ">=", ">", "==", "within_range", "preserve", "reduce_by_at_least", "priority"]
          },
          "threshold": {"type": "number"},
          "threshold_min": {"type": "number"},
          "threshold_max": {"type": "number"},
          "priority": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "scope": {"type": "string"},
          "baseline_ref": {"type": "string"},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "protected_features": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "feature_id": {"type": "string"},
                "feature_type": {"type": "string"},
                "interface_role": {"type": "string"},
                "protected_reason": {"type": "string"}
              }
            }
          },
          "protected_interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "interface_id": {"type": "string"},
                "interface_type": {"type": "string"}
              }
            }
          },
          "objective_order": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets_are_acceptance_criteria",
        "compliance_requires_evidence",
        "physical_correctness_not_claimed"
      ],
      "properties": {
        "targets_are_acceptance_criteria": {"type": "boolean", "const": true},
        "compliance_requires_evidence": {"type": "boolean", "const": true},
        "physical_correctness_not_claimed": {"type": "boolean", "const": true}
      }
    }
  }
}
