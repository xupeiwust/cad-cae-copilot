{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/interface_graph.schema.json",
  "title": ".aieng interface graph",
  "description": "Generated engineering interface index for .aieng packages. Identifies interface-related features and references from existing structured context.",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_files",
    "interfaces",
    "notes"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.interface_graph"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/interface_entry"
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "interface_entry": {
      "type": "object",
      "required": [
        "id",
        "type",
        "feature_ids",
        "topology_refs",
        "roles",
        "protected",
        "constraint_refs",
        "simulation_refs",
        "visual_refs",
        "allowed_operations",
        "forbidden_operations",
        "status",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "mounting_interface",
            "protected_external_interface",
            "fixed_support_interface",
            "load_interface",
            "context_interface",
            "cae_mapped_interface"
          ]
        },
        "feature_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "topology_refs": {
          "type": "object",
          "required": [
            "faces",
            "edges"
          ],
          "properties": {
            "faces": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protected": {
          "type": "boolean"
        },
        "constraint_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "simulation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "visual_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cae_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cae_ref"
          }
        },
        "allowed_operations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_operations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "cae_ref": {
      "type": "object",
      "required": [
        "cae_entity",
        "cae_type",
        "source_file",
        "mapping_status",
        "mapping_method",
        "confidence",
        "maps_to"
      ],
      "properties": {
        "cae_entity": {
          "type": "string",
          "minLength": 1
        },
        "cae_type": {
          "type": "string",
          "enum": [
            "boundary_condition_target",
            "load_target"
          ]
        },
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "mapping_status": {
          "type": "string",
          "enum": [
            "mapped",
            "unmapped",
            "partially_mapped",
            "unresolved"
          ]
        },
        "mapping_method": {
          "type": "string",
          "enum": [
            "not_inferred_phase_10a",
            "user_provided"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        },
        "maps_to": {
          "type": "object",
          "properties": {
            "feature_id": {
              "type": "string",
              "minLength": 1
            },
            "interface_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false,
          "minProperties": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$comment": "The interface graph is generated from existing structured files and is not source-of-truth data."
}
