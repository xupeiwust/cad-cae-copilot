{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/manifest.schema.json",
  "title": ".aieng manifest",
  "type": "object",
  "required": [
    "model_id",
    "format_version",
    "units",
    "resources",
    "created_by"
  ],
  "properties": {
    "source_mode": {
      "enum": [
        "step",
        "definition",
        "converter"
      ],
      "description": "Optional source mode for packages created from imported STEP geometry, structured definitions, or a registered CAD/CAE converter (Phase 20)."
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$",
      "description": "Stable model identifier used across package resources."
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Supported .aieng schema/package version."
    },
    "units": {
      "type": "object",
      "required": [
        "length",
        "mass",
        "force",
        "stress"
      ],
      "properties": {
        "length": {
          "type": "string",
          "minLength": 1
        },
        "mass": {
          "type": "string",
          "minLength": 1
        },
        "force": {
          "type": "string",
          "minLength": 1
        },
        "stress": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Canonical engineering units for interpreting package resources."
    },
    "resources": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              ]
            }
          }
        ]
      },
      "description": "Typed resource index. Values are package-relative paths or nested maps of package-relative paths."
    },
    "created_by": {
      "type": "object",
      "required": [
        "tool",
        "created_at"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true,
      "description": "Creation provenance for traceability; not engineering validation evidence."
    }
  },
  "additionalProperties": false,
  "description": "Package-level index for a self-describing .aieng engineering model repository. The manifest identifies the model, units, typed resources, and provenance; future versions should also index validation state, visual mappings, and allowed-operation resources.",
  "$comment": "The manifest should help a general AI discover structured engineering meaning before calling CAD/CAE tools. Phase 0 keeps only the required minimal fields."
}
