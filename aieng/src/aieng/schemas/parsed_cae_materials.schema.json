{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/parsed_cae_materials.schema.json",
  "title": ".aieng parsed CAE materials",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_file",
    "materials",
    "parser"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.parsed_cae_materials"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_file": {
      "type": "string",
      "const": "simulation/cae_imports/source_solver_deck.inp"
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "elastic": {
            "type": "object",
            "required": [
              "youngs_modulus",
              "poisson_ratio"
            ],
            "properties": {
              "youngs_modulus": {
                "type": "number"
              },
              "poisson_ratio": {
                "type": "number"
              }
            },
            "additionalProperties": false
          },
          "density": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "parser": {
      "type": "object",
      "required": [
        "format",
        "scope"
      ],
      "properties": {
        "format": {
          "type": "string",
          "const": "calculix"
        },
        "scope": {
          "type": "string",
          "const": "phase_10a_minimal_cards"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
