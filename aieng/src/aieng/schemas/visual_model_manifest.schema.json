{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/visual_model_manifest.schema.json",
  "title": ".aieng visual model manifest",
  "description": "Structured visual resource manifest for .aieng packages. Distinguishes annotation metadata from rendered/viewable assets.",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_files",
    "visual_resources",
    "rendering_status",
    "claim_policy"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.visual_model_manifest"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "visual_resources": {
      "type": "object",
      "required": [
        "annotation_layers",
        "model_gltf",
        "feature_snapshots",
        "screenshots"
      ],
      "properties": {
        "annotation_layers": {
          "$ref": "#/$defs/resource_entry"
        },
        "model_gltf": {
          "$ref": "#/$defs/resource_entry"
        },
        "feature_snapshots": {
          "$ref": "#/$defs/resource_entry"
        },
        "screenshots": {
          "$ref": "#/$defs/resource_entry"
        }
      },
      "additionalProperties": false
    },
    "rendering_status": {
      "type": "object",
      "required": [
        "rendered_geometry_present",
        "screenshots_present",
        "feature_snapshots_present",
        "viewer_ready"
      ],
      "properties": {
        "rendered_geometry_present": {
          "type": "boolean"
        },
        "screenshots_present": {
          "type": "boolean"
        },
        "feature_snapshots_present": {
          "type": "boolean"
        },
        "viewer_ready": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "claim_policy": {
      "type": "object",
      "required": [
        "allowed_claims",
        "forbidden_claims"
      ],
      "properties": {
        "allowed_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "forbidden_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "resource_entry": {
      "type": "object",
      "required": [
        "path",
        "status",
        "type",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "present",
            "missing",
            "not_generated"
          ]
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$comment": "Phase 8B scaffold only. This schema does not imply rendered geometry generation."
}
