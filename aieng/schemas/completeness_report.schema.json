{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/completeness_report.schema.json",
  "title": ".aieng completeness and missingness report",
  "description": "Best-effort conversion report that states which CAD/CAE semantic information is available, partial, missing, unknown, unsupported, conflicting, or not applicable. Missing information must be explicit rather than inferred or fabricated.",
  "type": "object",
  "required": [
    "format_version",
    "report_id",
    "model_id",
    "generated_at_utc",
    "real_geometry_extraction",
    "conversion_mode",
    "claim_policy",
    "source_artifacts",
    "categories",
    "next_recommended_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "report_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "source_mode": {
      "type": "string",
      "enum": ["step", "definition", "converter", "unknown"]
    },
    "real_geometry_extraction": {
      "type": "boolean",
      "description": "True only when topology metadata confirms real STEP parsing by the OCC backend."
    },
    "conversion_mode": {"type": "string", "const": "best_effort"},
    "claim_policy": {"$ref": "#/$defs/ClaimPolicy"},
    "source_artifacts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/CompletenessCategory"}
    },
    "next_recommended_actions": {
      "type": "array",
      "items": {"$ref": "#/$defs/RecommendedAction"}
    }
  },
  "$defs": {
    "ClaimPolicy": {
      "type": "object",
      "required": [
        "best_effort_conversion",
        "missingness_explicit",
        "do_not_infer_missing_information",
        "unsupported_is_not_false",
        "external_tools_execute",
        "aieng_core_executes_external_tools"
      ],
      "additionalProperties": false,
      "properties": {
        "best_effort_conversion": {"type": "boolean", "const": true},
        "missingness_explicit": {"type": "boolean", "const": true},
        "do_not_infer_missing_information": {"type": "boolean", "const": true},
        "unsupported_is_not_false": {"type": "boolean", "const": true},
        "external_tools_execute": {"type": "boolean", "const": true},
        "aieng_core_executes_external_tools": {"type": "boolean", "const": false}
      }
    },
    "CompletenessCategory": {
      "type": "object",
      "required": ["category", "status", "resources", "missing_items", "required_for", "notes"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "geometry",
            "topology",
            "adjacency",
            "features",
            "protected_regions",
            "constraints",
            "simulation_setup",
            "cae_imports",
            "cae_mapping",
            "mesh_handoff_contract",
            "task_contract",
            "external_tool_handoff",
            "evidence_ledger",
            "mesh_artifacts",
            "claim_map",
            "provenance_trace",
            "validation_status",
            "visual_resources",
            "object_registry",
            "interface_graph",
            "patch_proposals",
            "source_conversion"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["available", "partial", "missing", "unknown", "unsupported", "conflicting", "not_applicable"]
        },
        "resources": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "missing_items": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "required_for": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "RecommendedAction": {
      "type": "object",
      "required": ["action", "reason"],
      "additionalProperties": false,
      "properties": {
        "action": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  },
  "$comment": "Phase 16A: best-effort semantic conversion with explicit missingness. Absence must be recorded as missing/unknown/unsupported rather than guessed."
}

