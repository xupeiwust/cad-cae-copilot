{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/pareto_front.schema.json",
  "title": ".aieng Pareto front",
  "description": "Advisory non-dominated set of feasible evaluated candidates for a two-objective design study.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema_version",
    "status",
    "study_id",
    "design_study_problem_ref",
    "objectives",
    "front",
    "dominated",
    "candidate_count",
    "claim_policy",
    "provenance",
    "limitations"
  ],
  "properties": {
    "format": {"const": "aieng.pareto_front"},
    "format_version": {"type": "string"},
    "schema_version": {"const": "0.1"},
    "status": {"type": "string", "minLength": 1},
    "study_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "design_study_problem_ref": {"const": "analysis/design_study_problem.json"},
    "design_study_problem_id": {"type": ["string", "null"]},
    "objectives": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "metric", "sense"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "metric": {"type": "string", "minLength": 1},
          "sense": {"enum": ["minimize", "maximize", "reduce", "improve"]},
          "unit": {"type": ["string", "null"]}
        }
      }
    },
    "front": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "value_1", "value_2"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "rank": {"type": "integer", "minimum": 1},
          "value_1": {"type": "number"},
          "value_2": {"type": "number"}
        }
      }
    },
    "front_candidate_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "dominated": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "dominated_candidate_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "candidate_count": {"type": "integer", "minimum": 0},
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "claim_policy": {"$ref": "#/$defs/claim_policy"},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by", "claim_advancement"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "audit_event_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "claim_advancement": {"const": "none"}
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_only",
        "baseline_unchanged",
        "human_approval_required_for_acceptance",
        "claim_advancement"
      ],
      "properties": {
        "advisory_only": {"const": true},
        "baseline_unchanged": {"const": true},
        "human_approval_required_for_acceptance": {"const": true},
        "claim_advancement": {"const": "none"}
      }
    }
  }
}
