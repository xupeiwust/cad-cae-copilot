{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/field_regions.schema.json",
  "title": ".aieng field regions",
  "description": "High-magnitude field clusters extracted from an external solver result file. Observational only: this artifact does not claim physical correctness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "format_version",
    "source_frd",
    "field",
    "metric",
    "cluster_count",
    "clusters",
    "warnings",
    "claim_policy"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "format_version": {"type": "string", "const": "0.1.0"},
    "source_frd": {"type": "string", "minLength": 1},
    "field": {"type": "string", "minLength": 1},
    "metric": {"type": "string", "minLength": 1},
    "cluster_count": {"type": "integer", "minimum": 0},
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "location", "magnitude", "node_count", "feature_ref"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "z"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "z": {"type": "number"}
            }
          },
          "magnitude": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "unit"],
            "properties": {
              "value": {"type": "number"},
              "unit": {"type": "string"}
            }
          },
          "node_count": {"type": "integer", "minimum": 1},
          "feature_ref": {
            "description": "Feature ID when mesh-to-feature mapping evidence exists; null when unavailable.",
            "type": ["string", "null"]
          }
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observational_only",
        "physical_correctness_not_claimed",
        "solver_execution_not_performed_by_aieng"
      ],
      "properties": {
        "observational_only": {"type": "boolean", "const": true},
        "physical_correctness_not_claimed": {"type": "boolean", "const": true},
        "solver_execution_not_performed_by_aieng": {"type": "boolean", "const": true}
      }
    }
  }
}
