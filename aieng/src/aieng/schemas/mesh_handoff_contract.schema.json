{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/mesh_handoff_contract.schema.json",
  "title": ".aieng mesh handoff contract",
  "type": "object",
  "required": [
    "format_version",
    "handoff_id",
    "generated_by",
    "generated_at_utc",
    "geometry_source",
    "mesher_target",
    "mesh_recommendations",
    "topology_refs",
    "target_claim_ids",
    "execution_boundary",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "0.1.0"},
    "handoff_id": {"type": "string", "minLength": 1},
    "generated_by": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "geometry_source": {"type": "string", "minLength": 1},
    "mesher_target": {"type": "string", "enum": ["gmsh"]},
    "mesh_recommendations": {
      "type": "object",
      "required": ["element_type"],
      "additionalProperties": false,
      "properties": {
        "element_type": {"type": "string", "enum": ["tetra", "hexa", "mixed"]},
        "global_element_size": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "topology_refs": {
      "type": "object",
      "required": ["body_ids", "face_ids", "edge_ids"],
      "additionalProperties": false,
      "properties": {
        "body_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "face_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "edge_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "target_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "execution_boundary": {
      "type": "object",
      "required": ["external_tools_execute", "aieng_core_executes_mesher"],
      "additionalProperties": false,
      "properties": {
        "external_tools_execute": {"type": "boolean", "const": true},
        "aieng_core_executes_mesher": {"type": "boolean", "const": false}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$comment": "Phase 17B handoff contract for external meshing; .aieng core does not execute mesh generation."
}
