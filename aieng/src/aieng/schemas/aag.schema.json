{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/aag.schema.json",
  "title": ".aieng attributed adjacency graph",
  "type": "object",
  "required": [
    "schema_version",
    "source_topology_map",
    "generation_method",
    "nodes",
    "arcs",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_topology_map": {
      "type": "string",
      "const": "geometry/topology_map.json"
    },
    "generation_method": {
      "type": "object",
      "required": [
        "builder"
      ],
      "properties": {
        "builder": {
          "type": "string"
        },
        "topology_backend": {
          "type": "string"
        },
        "adjacency_evidence": {
          "enum": [
            "real",
            "inferred",
            "mock",
            "unavailable",
            "unknown"
          ]
        }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "topology_entity_id",
          "entity_type",
          "surface_type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "topology_entity_id": {
            "type": "string",
            "minLength": 1
          },
          "entity_type": {
            "const": "face"
          },
          "surface_type": {
            "type": "string"
          },
          "area": {
            "type": "number"
          },
          "bbox": {
            "type": "array",
            "minItems": 6,
            "maxItems": 6,
            "items": {
              "type": "number"
            }
          },
          "normal": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          },
          "axis": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          },
          "radius": {
            "type": "number"
          },
          "feature_hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "arcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source_node",
          "target_node",
          "shared_edge_ids",
          "adjacency_type",
          "edge_continuity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source_node": {
            "type": "string",
            "minLength": 1
          },
          "target_node": {
            "type": "string",
            "minLength": 1
          },
          "shared_edge_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "adjacency_type": {
            "enum": [
              "edge_adjacent",
              "inferred_from_topology",
              "unknown"
            ]
          },
          "edge_continuity": {
            "enum": [
              "convex",
              "concave",
              "tangent",
              "smooth",
              "unknown"
            ]
          },
          "dihedral_angle_degrees": {
            "type": "number"
          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low",
              "unknown"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "description": "Generated face-level attributed adjacency graph (AAG). This is an index derived from topology_map and is not source-of-truth geometry data."
}
