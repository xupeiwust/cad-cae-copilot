{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/optimization_decision_log.schema.json",
  "title": ".aieng optimization decision log",
  "description": "Reason-coded, machine-auditable backend and agent decisions for an optimization study.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema_version",
    "study_id",
    "design_study_problem_ref",
    "entries",
    "candidate_ids",
    "provenance",
    "claim_policy"
  ],
  "properties": {
    "format": {
      "const": "aieng.optimization_decision_log"
    },
    "schema_version": {
      "const": "0.1"
    },
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "design_study_problem_ref": {
      "const": "analysis/design_study_problem.json"
    },
    "design_study_problem_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "timestamp",
          "decision",
          "reason_codes",
          "requires_human_review",
          "candidate_ids"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "reason_codes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "initial_mvp",
                "user_selected",
                "no_gradient_available",
                "discrete_variables_present",
                "small_number_of_design_variables",
                "expensive_cae_eval",
                "cae_evaluation_available",
                "static_metrics_only",
                "constraint_violation",
                "candidate_build_failed",
                "candidate_evaluation_failed",
                "candidate_out_of_bounds",
                "protected_parameter",
                "duplicate_candidate",
                "candidate_cap_reached",
                "missing_metric",
                "unknown_feasibility",
                "needs_more_evaluation",
                "converged_objective_delta",
                "budget_exhausted",
                "needs_user_input",
                "human_approval_required",
                "advisory_recommendation",
                "proposer_exhausted",
                "max_consecutive_failures",
                "local_refinement",
                "no_incumbent_fallback",
                "trust_region_shrink",
                "select_slsqp",
                "select_bayesian",
                "select_genetic",
                "no_surrogate_available",
                "continuous_smooth_problem"
              ]
            }
          },
          "requires_human_review": {
            "type": "boolean"
          },
          "candidate_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "metric_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "candidate_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "claim_policy": {
      "$ref": "#/$defs/claim_policy"
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "created_by",
        "claim_advancement"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        },
        "audit_event_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "claim_advancement": {
          "const": "none"
        }
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_only",
        "baseline_unchanged",
        "human_approval_required_for_acceptance",
        "claim_advancement"
      ],
      "properties": {
        "advisory_only": {
          "const": true
        },
        "baseline_unchanged": {
          "const": true
        },
        "human_approval_required_for_acceptance": {
          "const": true
        },
        "claim_advancement": {
          "const": "none"
        }
      }
    }
  }
}
