{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_trace.schema.json",
  "title": "ToolTrace",
  "description": "Provenance record of external tool execution steps for a .aieng package. Records what external tools did; .aieng does not execute them.",
  "type": "object",
  "required": ["format_version", "tool_trace_id", "entries", "claim_policy"],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "tool_trace_id": {
      "type": "string",
      "minLength": 1
    },
    "source_task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "adapter_metadata": {
      "type": "object",
      "description": "Optional metadata about the adapter's capabilities and limitations (G11 gate)",
      "additionalProperties": false,
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier for this adapter (e.g., 'importer_step_v1')"
        },
        "adapter_role": {
          "type": "string",
          "enum": [
            "importer_step",
            "importer_cae_deck",
            "importer_solver_evidence",
            "importer_mesh_evidence",
            "exporter_calculix",
            "exporter_updated_deck",
            "tool_trace_recorder",
            "evidence_recorder"
          ],
          "description": "Role of this adapter in the workflow"
        },
        "capability_level": {
          "type": "integer",
          "enum": [0, 1, 2, 3, 4, 5],
          "description": "L0-L5 maturity level: 0=scaffold_only, 1=import_only, 2=partial_extraction, 3=structured_mapping, 4=validated_roundtrip, 5=deterministic_edit"
        },
        "supported_resources": {
          "type": "array",
          "description": "List of .aieng resource types this adapter can read/write",
          "items": {
            "type": "string"
          }
        },
        "known_limitations": {
          "type": "array",
          "description": "Explicit limitations and unknowns for this adapter",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "category": {
                "type": "string",
                "enum": [
                  "geometry",
                  "topology",
                  "features",
                  "constraints",
                  "simulation_setup",
                  "mesh",
                  "results",
                  "validation"
                ]
              },
              "description": {
                "type": "string"
              }
            },
            "required": ["category", "description"]
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TraceEntry"
      }
    },
    "claim_policy": {
      "$ref": "#/$defs/ClaimPolicy"
    }
  },
  "$defs": {
    "TraceEntry": {
      "type": "object",
      "required": ["entry_id", "timestamp_utc", "tool", "step", "artifacts_recorded", "claims_advanced", "notes"],
      "additionalProperties": false,
      "properties": {
        "entry_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp_utc": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "$ref": "#/$defs/ToolRef"
        },
        "step": {
          "$ref": "#/$defs/StepRecord"
        },
        "artifacts_recorded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claims_advanced": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ToolRef": {
      "type": "object",
      "required": ["tool_id", "tool_role"],
      "additionalProperties": false,
      "properties": {
        "tool_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_role": {
          "type": "string",
          "enum": [
            "agent_runtime",
            "cad_runtime",
            "cae_runtime",
            "cae_preprocessor",
            "solver",
            "postprocessor",
            "manufacturing_checker"
          ]
        },
        "version": {
          "type": "string"
        }
      }
    },
    "StepRecord": {
      "type": "object",
      "required": ["name", "inputs", "outputs", "exit_status"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_status": {
          "type": "string",
          "enum": ["success", "failure", "skipped"]
        }
      }
    },
    "ClaimPolicy": {
      "type": "object",
      "required": ["external_tools_execute", "aieng_core_executes_external_tools"],
      "additionalProperties": false,
      "properties": {
        "external_tools_execute": {
          "type": "boolean",
          "const": true
        },
        "aieng_core_executes_external_tools": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
