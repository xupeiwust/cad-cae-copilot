{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/protected_regions.schema.json",
  "title": ".aieng protected regions",
  "type": "object",
  "required": [
    "format_version",
    "protected_regions"
  ],
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "protected_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feature_id",
          "reason",
          "allowed_operations",
          "forbidden_operations"
        ],
        "properties": {
          "feature_id": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "allowed_operations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_operations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
