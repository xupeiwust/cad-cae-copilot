{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/optimization_objectives.schema.json",
  "title": ".aieng optimization objectives",
  "description": "Advisory objective definitions derived from the existing design-study objective.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schema_version", "study_id", "design_study_problem_ref", "objectives", "candidate_ids", "provenance", "claim_policy"],
  "properties": {
    "format": {"const": "aieng.optimization_objectives"},
    "schema_version": {"const": "0.1"},
    "study_id": {"type": "string", "minLength": 1},
    "design_study_problem_ref": {"const": "analysis/design_study_problem.json"},
    "design_study_problem_id": {"type": ["string", "null"]},
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "metric", "direction", "weight", "candidate_ids", "evidence_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "metric": {"type": "string", "minLength": 1},
          "direction": {"enum": ["minimize", "maximize", "target"]},
          "weight": {"type": "number", "minimum": 0},
          "target_value": {"type": ["number", "null"]},
          "unit": {"type": ["string", "null"]},
          "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "provenance": {"$ref": "#/$defs/provenance"},
    "claim_policy": {"$ref": "#/$defs/claim_policy"}
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by", "claim_advancement"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "audit_event_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "claim_advancement": {"const": "none"}
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advisory_only", "baseline_unchanged", "human_approval_required_for_acceptance", "claim_advancement"],
      "properties": {
        "advisory_only": {"const": true},
        "baseline_unchanged": {"const": true},
        "human_approval_required_for_acceptance": {"const": true},
        "claim_advancement": {"const": "none"}
      }
    }
  }
}
