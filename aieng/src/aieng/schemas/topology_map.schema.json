{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/topology_map.schema.json",
  "title": ".aieng topology map",
  "type": "object",
  "required": [
    "format_version",
    "entities"
  ],
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Supported topology-map schema version."
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "solid",
              "shell",
              "face",
              "wire",
              "edge",
              "vertex"
            ]
          },
          "surface_type": {
            "type": "string"
          },
          "bounding_box": {
            "type": "array",
            "minItems": 6,
            "maxItems": 6,
            "items": {
              "type": "number"
            }
          },
          "area": {
            "type": "number"
          },
          "normal": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          },
          "axis": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          },
          "radius": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "body_id": {
            "type": "string"
          },
          "curve_type": {
            "type": "string"
          },
          "face_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "edge_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "adjacent_entity_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      },
      "description": "Stable topology entities that features, constraints, visual mappings, and patches can reference."
    },
    "metadata": {
      "type": "object",
      "description": "Extractor provenance, limitations, and non-authoritative metadata for AI-readable topology context.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "description": "Stable topology and geometry reference map. This is the bridge from exact geometry resources to AI-readable feature semantics; it should expose enough identifiers and geometric attributes for basic understanding without requiring direct CAD-kernel inspection.",
  "$comment": "Future versions may add visual selection mappings, persistent naming metadata, extraction provenance, and confidence/uncertainty fields."
}
