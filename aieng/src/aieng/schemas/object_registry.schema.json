{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/object_registry.schema.json",
  "title": ".aieng object registry",
  "description": "Generated cross-resource object index for .aieng packages. This is a navigation index, not the source of truth.",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_files",
    "objects",
    "relationships",
    "notes"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.object_registry"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/object_entry"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship_entry"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "$defs": {
    "object_entry": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "referenced_by",
        "roles",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "topology_entity",
            "feature",
            "constraint",
            "simulation",
            "boundary_condition",
            "load",
            "material",
            "cae_material",
            "cae_boundary_condition",
            "cae_load",
            "cae_mapping",
            "protected_region",
            "patch",
            "patch_operation",
            "visual_annotation",
            "visual_resource",
            "interface",
            "validation_status",
            "unresolved_reference"
          ]
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "defined_in": {
          "type": "string"
        },
        "referenced_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "relationship_entry": {
      "type": "object",
      "required": [
        "from",
        "to",
        "type",
        "source_file"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$comment": "The object registry is an AI/tool navigation aid. Source JSON/YAML resources remain authoritative."
}
