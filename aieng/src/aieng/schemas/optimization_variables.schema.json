{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/optimization_variables.schema.json",
  "title": ".aieng resolved optimization variables",
  "description": "Resolved editable-parameter bindings derived from analysis/design_study_problem.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schema_version", "study_id", "design_study_problem_ref", "variables", "candidate_ids", "provenance", "claim_policy"],
  "properties": {
    "format": {"const": "aieng.optimization_variables"},
    "schema_version": {"const": "0.2"},
    "study_id": {"type": "string", "minLength": 1},
    "design_study_problem_ref": {"const": "analysis/design_study_problem.json"},
    "design_study_problem_id": {"type": ["string", "null"]},
    "variables": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/variable"}},
    "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "provenance": {"$ref": "#/$defs/provenance"},
    "claim_policy": {"$ref": "#/$defs/claim_policy"}
  },
  "$defs": {
    "value": {"type": ["number", "integer", "string", "boolean", "null"]},
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "type", "featureId", "parameterName", "cad_parameter_name", "binding_status", "current_value", "min_value", "max_value", "allowed_values", "unit", "scope", "safe_to_modify", "candidate_ids"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "type": {"enum": ["continuous", "integer", "discrete", "categorical", "boolean"]},
        "featureId": {"type": ["string", "null"]},
        "parameterName": {"type": ["string", "null"]},
        "cad_parameter_name": {"type": ["string", "null"]},
        "binding_status": {"enum": ["bound", "unverified", "not_found", "ambiguous"]},
        "current_value": {"$ref": "#/$defs/value"},
        "min_value": {"type": ["number", "null"]},
        "max_value": {"type": ["number", "null"]},
        "allowed_values": {"type": ["array", "null"], "items": {"$ref": "#/$defs/value"}},
        "unit": {"type": ["string", "null"]},
        "scope": {"enum": ["local", "global", "unscoped"]},
        "safe_to_modify": {"type": "boolean"},
        "semantic_role": {"type": ["string", "null"]},
        "shape_bearing": {"type": "boolean"},
        "candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {"if": {"properties": {"type": {"enum": ["continuous", "integer"]}}}, "then": {"properties": {"min_value": {"type": "number"}, "max_value": {"type": "number"}}}},
        {"if": {"properties": {"type": {"enum": ["discrete", "categorical"]}}}, "then": {"properties": {"allowed_values": {"type": "array", "minItems": 1}}}},
        {"if": {"properties": {"binding_status": {"const": "bound"}}}, "then": {"properties": {"featureId": {"type": "string", "minLength": 1}, "parameterName": {"type": "string", "minLength": 1}, "cad_parameter_name": {"type": "string", "minLength": 1}}}}
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by", "claim_advancement"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "audit_event_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "claim_advancement": {"const": "none"}
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advisory_only", "baseline_unchanged", "human_approval_required_for_acceptance", "claim_advancement"],
      "properties": {
        "advisory_only": {"const": true},
        "baseline_unchanged": {"const": true},
        "human_approval_required_for_acceptance": {"const": true},
        "claim_advancement": {"const": "none"}
      }
    }
  }
}
