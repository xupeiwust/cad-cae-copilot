{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/nafems_vv_report.schema.json",
  "title": ".aieng NAFEMS-style V&V report",
  "description": "Machine-readable report for NAFEMS-style linear-static verification regression cases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "schema_version",
    "status",
    "cases",
    "claim_policy",
    "limitations"
  ],
  "properties": {
    "format": {"const": "aieng.nafems_vv_report"},
    "format_version": {"type": "string"},
    "schema_version": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped"]
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["case_id", "verdict", "metrics"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "verdict": {
            "type": "string",
            "enum": ["pass", "fail", "skipped"]
          },
          "status": {
            "type": ["string", "null"],
            "enum": ["ok", "error", "skipped", null]
          },
          "message": {"type": ["string", "null"]},
          "missing_tools": {
            "type": ["array", "null"],
            "items": {"type": "string"}
          },
          "solver_log_tail": {"type": ["string", "null"]},
          "metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "metric",
                "reference",
                "computed",
                "deviation_percent",
                "tolerance_percent",
                "verdict"
              ],
              "properties": {
                "metric": {"type": "string", "minLength": 1},
                "reference": {"type": "number"},
                "computed": {"type": ["number", "null"]},
                "deviation_percent": {"type": ["number", "null"]},
                "tolerance_percent": {"type": "number"},
                "gating": {
                  "type": "boolean",
                  "description": "Whether this metric contributes to the case pass/fail verdict. Non-gating metrics remain reported for transparency."
                },
                "verdict": {
                  "type": "string",
                  "enum": ["pass", "fail", "skipped"]
                },
                "message": {"type": ["string", "null"]}
              }
            }
          },
          "mesh_convergence": {
            "type": "object",
            "description": "Optional mesh-refinement study for this case.",
            "additionalProperties": true,
            "required": ["case_id", "division_levels", "levels", "summary"],
            "properties": {
              "case_id": {"type": "string"},
              "division_levels": {
                "type": "array",
                "items": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 3,
                  "items": {"type": "integer"}
                }
              },
              "levels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["divisions", "run_id", "status"],
                  "properties": {
                    "divisions": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "items": {"type": "integer"}
                    },
                    "run_id": {"type": "string"},
                    "status": {"type": "string"},
                    "verdict": {"type": "string"},
                    "message": {"type": ["string", "null"]},
                    "metrics": {"type": "array"}
                  }
                }
              },
              "summary": {"type": "string"}
            }
          }
        }
      }
    },
    "claim_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "verification_is_pre_execution",
        "verification_does_not_replace_resimulation",
        "physical_correctness_not_claimed",
        "geometry_kernel_checks_not_performed",
        "claims_advanced"
      ],
      "properties": {
        "verification_is_pre_execution": {"type": "boolean"},
        "verification_does_not_replace_resimulation": {"type": "boolean"},
        "physical_correctness_not_claimed": {"type": "boolean"},
        "geometry_kernel_checks_not_performed": {"type": "boolean"},
        "claims_advanced": {"type": "boolean"}
      }
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
