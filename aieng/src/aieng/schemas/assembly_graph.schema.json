{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/assembly_graph.schema.json",
  "title": ".aieng assembly graph",
  "description": "Multi-part assembly graph for .aieng packages. Captures mating relationships, interface references, and assembly-level claim policy without requiring a geometry kernel.",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "parts",
    "mates",
    "coordinate_system",
    "claim_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.assembly_graph"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Input files used to build this graph."
    },
    "parts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/part_entry"
      }
    },
    "mates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mate_entry"
      }
    },
    "coordinate_system": {
      "$ref": "#/$defs/coordinate_system"
    },
    "claim_policy": {
      "$ref": "#/$defs/claim_policy"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "part_entry": {
      "type": "object",
      "required": ["part_id", "label"],
      "additionalProperties": false,
      "properties": {
        "part_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "step_ref": {
          "type": "string",
          "description": "Path to the STEP file for this part, relative to the package root."
        },
        "aieng_package_ref": {
          "type": "string",
          "description": "Path or identifier of the .aieng package for this part."
        }
      }
    },
    "mate_entry": {
      "type": "object",
      "required": ["mate_id", "part_a", "part_b", "mate_type"],
      "additionalProperties": false,
      "properties": {
        "mate_id": {
          "type": "string",
          "minLength": 1
        },
        "part_a": {
          "type": "string",
          "minLength": 1
        },
        "part_b": {
          "type": "string",
          "minLength": 1
        },
        "mate_type": {
          "type": "string",
          "enum": [
            "planar",
            "cylindrical",
            "coincident",
            "parallel",
            "perpendicular",
            "fixed",
            "revolute",
            "slider",
            "pin_slot",
            "custom"
          ]
        },
        "interface_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Interface IDs (from objects/interface_graph.json) that participate in this mate."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "coordinate_system": {
      "type": "object",
      "required": ["frame"],
      "additionalProperties": false,
      "properties": {
        "frame": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "claim_policy": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "additionalProperties": false,
      "properties": {
        "allowed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
