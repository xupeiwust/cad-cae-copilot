{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/feature_graph.schema.json",
  "title": ".aieng feature graph",
  "type": "object",
  "required": [
    "format_version",
    "features"
  ],
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Supported feature-graph schema version."
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "name",
          "geometry_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "named_part",
              "standard_part",
              "base_plate",
              "mounting_hole",
              "mounting_hole_pattern",
              "rib",
              "fillet",
              "chamfer",
              "boss",
              "flange",
              "interface_face",
              "unknown_feature"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "geometry_refs": {
            "description": "Topology references used by this feature. Object form is preferred; array form is retained for backward compatibility.",
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "object",
                "properties": {
                  "faces": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "edges": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "entities": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "body": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "parameters": {
            "type": "object"
          },
          "parameter_source": {
            "enum": ["mock", "ocp_extracted", "user_provided", "agent_defined", "cadquery_parametric", "converter_extracted"],
            "description": "Origin of the parameter values: mock placeholder, OCP measurement, user correction, agent definition, an executable parametric CAD source, or a CAD/CAE converter that lifted parameters from the source document (Phase 20)."
          },
          "editable": {
            "type": "boolean",
            "description": "Backward-compatible flag: whether an AI agent may propose or apply semantic parameter changes. This does not by itself imply CAD geometry write-back."
          },
          "editability": {
            "enum": [
              "not_editable",
              "semantic_only",
              "proposal_allowed",
              "executable_by_regeneration",
              "executable_by_direct_modeling"
            ],
            "description": "Execution level for parameter edits. Mock and OCP-extracted values should normally be semantic_only/proposal_allowed; executable_by_regeneration requires an explicit parametric source."
          },
          "writeback_strategy": {
            "enum": [
              "none",
              "semantic_parameter_update_only",
              "cadquery_regeneration",
              "direct_modeling"
            ],
            "description": "How a parameter edit can be written back to CAD/CAE artifacts, if at all. Direct modeling is reserved for future kernel-specific implementations."
          },
          "editability_reason": {
            "type": "string",
            "description": "Human-readable explanation of why this feature is or is not executable for write-back."
          },
          "parameter_confidence": {
            "enum": ["high", "medium", "low"],
            "description": "Confidence that the parameter values reflect real engineering intent."
          },
          "intent": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "source_feature_id": {
                  "type": "string"
                },
                "target_feature_id": {
                  "type": "string"
                },
                "feature_id": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "recognition": {
            "type": "object",
            "required": [
              "method",
              "confidence"
            ],
            "properties": {
              "method": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            },
            "additionalProperties": true
          },
          "standard_part": {
            "type": "boolean",
            "description": "True when this feature represents a recognized catalogue or standard mechanical part."
          },
          "source_library": {
            "type": "string",
            "description": "Source library for a recognized standard part, for example bd_warehouse when known."
          },
          "source_module": {
            "type": "string"
          },
          "source_class": {
            "type": "string"
          },
          "canonical_type": {
            "enum": [
              "fastener",
              "bearing",
              "gear",
              "thread",
              "flange",
              "washer",
              "nut",
              "screw",
              "bolt",
              "unknown_standard_part"
            ]
          },
          "designation": {
            "type": "string"
          },
          "original_label": {
            "type": "string"
          },
          "object_label": {
            "type": "string"
          },
          "detection_method": {
            "type": "string"
          },
          "confidence": {
            "enum": ["low", "medium", "high"]
          },
          "standard_part_metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "hole_metadata": {
            "type": "object",
            "description": "Optional geometric metadata for hole-like features, used by downstream fastener planning. Values must come from topology/feature evidence; unknowns should be omitted or marked with status fields rather than guessed.",
            "properties": {
              "axis": {
                "type": "object",
                "properties": {
                  "origin_mm": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": {
                      "type": "number"
                    }
                  },
                  "direction": {
                    "type": "array",
                    "minItems": 3,
                    "maxItems": 3,
                    "items": {
                      "type": "number"
                    }
                  },
                  "origin_source": {
                    "type": "string"
                  },
                  "direction_source": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "diameter_mm": {
                "type": "number"
              },
              "depth_mm": {
                "type": "number"
              },
              "through": {
                "type": "boolean"
              },
              "hole_depth_kind": {
                "enum": ["through", "blind", "unknown"]
              },
              "counterbore": {
                "type": "object",
                "additionalProperties": true
              },
              "countersink": {
                "type": "object",
                "additionalProperties": true
              },
              "mating_stack": {
                "type": "object",
                "properties": {
                  "status": {
                    "enum": ["known", "unknown", "ambiguous"]
                  },
                  "thickness_mm": {
                    "type": "number"
                  },
                  "candidate_count": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "source": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "description": "Engineering-level objects that make model meaning explicit to general AI systems."
    },
    "metadata": {
      "type": "object",
      "description": "Recognition provenance, limitations, and non-authoritative metadata for feature candidates.",
      "additionalProperties": true
    },
    "model_kind": {
      "enum": ["auto", "mechanical", "organic"],
      "description": "Heuristic model kind used to gate mechanical feature extraction."
    }
  },
  "additionalProperties": false,
  "description": "Engineering feature graph for AI-native understanding. Features should name design-relevant objects, reference topology IDs, expose parameters and intent, and support safe structured modification proposals.",
  "$comment": "Feature semantics are structured source-of-truth data, not merely a natural-language summary. Future versions may add validation state, confidence, allowed operations, and richer relationships."
}
