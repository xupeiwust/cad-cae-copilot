{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/parsed_cae_loads.schema.json",
  "title": ".aieng parsed CAE loads",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_file",
    "loads",
    "parser"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.parsed_cae_loads"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_file": {
      "type": "string",
      "const": "simulation/cae_imports/source_solver_deck.inp"
    },
    "loads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "target",
          "dof",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "dof": {
            "type": "integer"
          },
          "value": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "parser": {
      "type": "object",
      "required": [
        "format",
        "scope"
      ],
      "properties": {
        "format": {
          "type": "string",
          "const": "calculix"
        },
        "scope": {
          "type": "string",
          "const": "phase_10a_minimal_cards"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
