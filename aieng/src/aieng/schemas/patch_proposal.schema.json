{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/patch_proposal.schema.json",
  "title": ".aieng patch proposal",
  "type": "object",
  "required": [
    "patch_id",
    "created_by",
    "user_intent",
    "status",
    "summary",
    "operations",
    "protected_targets_checked",
    "protected_targets_avoided",
    "warnings",
    "expected_effects",
    "requires_validation",
    "source_files_consulted",
    "created_from",
    "no_geometry_modified",
    "no_solver_run"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "pattern": "^patch_[0-9]{4}$",
      "description": "Stable proposal identifier."
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "user_intent": {
      "type": "string",
      "minLength": 1,
      "description": "Human intent that motivated the structured proposal; not sufficient by itself for execution."
    },
    "status": {
      "enum": [
        "draft",
        "proposed",
        "needs_review",
        "ready_for_validation",
        "blocked",
        "violation",
        "violates_protected_target",
        "accepted",
        "rejected",
        "applied"
      ],
      "description": "Proposal lifecycle and protection/validation state. 'applied' means the executor has run and updated the semantic layer."
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "op": {
            "enum": [
              "modify_parameter",
              "add_feature",
              "remove_feature",
              "protect_feature",
              "assign_material",
              "assign_boundary_condition",
              "assign_load"
            ]
          },
          "type": {
            "enum": [
              "modify_parameter",
              "add_feature",
              "remove_feature",
              "protect_feature",
              "assign_material",
              "assign_boundary_condition",
              "assign_load"
            ]
          },
          "feature_type": {
            "type": "string"
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "target_feature_id": {
            "type": "string",
            "minLength": 1
          },
          "parameters": {
            "type": "object"
          },
          "rationale": {
            "type": "string"
          }
        },
        "anyOf": [
          {"required": ["op"]},
          {"required": ["type"]}
        ],
        "additionalProperties": false
      },
      "description": "Structured operations proposed for later deterministic validation and execution."
    },
    "target_feature_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Backward-compatible list of affected feature IDs."
    },
    "protected_target_checks": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Backward-compatible explicit checks against protected features or constraints."
    },
    "protected_targets_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "protected_targets_avoided": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_effects": {
      "type": "object",
      "additionalProperties": true,
      "description": "Expected qualitative or quantitative effects requiring later validation."
    },
    "required_validation_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Backward-compatible deterministic checks required before accepting engineering claims."
    },
    "requires_validation": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Deterministic checks required before accepting engineering claims."
    },
    "source_files_consulted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_from": {
      "type": "object",
      "required": [
        "method",
        "llm_used",
        "rag_used",
        "external_cad_tools_used"
      ],
      "properties": {
        "method": {
          "enum": ["rule_based"]
        },
        "llm_used": {
          "type": "boolean",
          "const": false
        },
        "rag_used": {
          "type": "boolean",
          "const": false
        },
        "external_cad_tools_used": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "no_geometry_modified": {
      "type": "boolean",
      "description": "True for unexecuted proposals. False when the executor produced a modified STEP file."
    },
    "no_solver_run": {
      "type": "boolean",
      "const": true
    },
    "execution_record": {
      "type": "object",
      "description": "Written by the executor when status transitions to 'applied'.",
      "properties": {
        "applied_operations": {"type": "integer"},
        "feature_graph_updated": {"type": "boolean"},
        "execution_mode": {
          "enum": ["semantic_parameter_update_only", "cad_writeback"]
        },
        "cad_writeback_attempted": {"type": "boolean"},
        "step_writeback": {"type": "string"},
        "step_output": {"type": ["string", "null"]},
        "roundtrip_required": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "description": "Structured unexecuted AI-native engineering modification proposal. Patch proposals must reference feature IDs, avoid protected targets, declare expected effects, and list deterministic validation steps before execution.",
  "$comment": "The LLM proposes nothing here; Phase 5B uses deterministic rule-based generation. Schemas constrain; validators, geometry kernels, meshers, and solvers must verify before engineering acceptance."
}
