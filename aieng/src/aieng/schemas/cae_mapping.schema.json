{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/cae_mapping.schema.json",
  "title": ".aieng CAE mapping",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "source_files",
    "mappings",
    "notes"
  ],
  "properties": {
    "format": {
      "type": "string",
      "const": "aieng.cae_mapping"
    },
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cae_entity",
          "cae_type",
          "maps_to",
          "mapping_status",
          "mapping_method",
          "confidence"
        ],
        "properties": {
          "cae_entity": {
            "type": "string",
            "minLength": 1
          },
          "cae_type": {
            "type": "string",
            "enum": [
              "boundary_condition_target",
              "load_target"
            ]
          },
          "maps_to": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "properties": {
                  "feature_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "interface_id": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false,
                "minProperties": 1
              }
            ]
          },
          "mapping_status": {
            "type": "string",
            "enum": [
              "mapped",
              "unmapped",
              "partially_mapped",
              "unresolved"
            ]
          },
          "mapping_method": {
            "type": "string",
            "enum": [
              "not_inferred_phase_10a",
              "user_provided"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "none",
              "low",
              "medium",
              "high"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mapping_summary": {
      "type": "object",
      "required": [
        "mapped_count",
        "unmapped_count"
      ],
      "properties": {
        "mapped_count": {
          "type": "integer",
          "minimum": 0
        },
        "unmapped_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "source_mapping_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
