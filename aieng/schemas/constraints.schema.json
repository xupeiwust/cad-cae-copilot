{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aieng.dev/schemas/constraints.schema.json",
  "title": ".aieng constraints",
  "type": "object",
  "required": [
    "format_version",
    "constraints"
  ],
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Supported constraints schema version."
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "target",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "protect_geometry",
              "protect_position",
              "protect_dimension",
              "min_value",
              "max_value",
              "preserve_interface",
              "manufacturing_rule",
              "simulation_target"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "parameter": {
            "type": "string"
          },
          "value": {},
          "metric": {
            "type": "string"
          },
          "operator": {
            "enum": [
              "<",
              "<=",
              ">",
              ">=",
              "=",
              "=="
            ]
          }
        },
        "additionalProperties": false
      },
      "description": "Machine-readable engineering constraints, protected regions, limits, and targets."
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "description": "Structured engineering constraints and protected targets. Constraints tell a general AI what must be preserved, limited, validated, or treated as a simulation/manufacturing target before proposing modifications.",
  "$comment": "External tools can validate constraints, but the package should carry enough constraint meaning for AI inspection before tool use."
}
