{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adapter_capability_manifest.schema.json",
  "title": "AdapterCapabilityManifest",
  "description": "Machine-readable declaration of adapter capabilities and limitations (G11 gate)",
  "type": "object",
  "required": ["format_version", "adapters"],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "timestamp_utc": {
      "type": "string",
      "description": "When this manifest was generated"
    },
    "adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AdapterDeclaration"
      }
    }
  },
  "$defs": {
    "AdapterDeclaration": {
      "type": "object",
      "required": [
        "adapter_id",
        "adapter_role",
        "capability_level",
        "supported_resources",
        "known_limitations"
      ],
      "additionalProperties": false,
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier for this adapter"
        },
        "adapter_role": {
          "type": "string",
          "enum": [
            "importer_step",
            "importer_cae_deck",
            "importer_solver_evidence",
            "importer_mesh_evidence",
            "exporter_calculix",
            "exporter_updated_deck",
            "tool_trace_recorder",
            "evidence_recorder"
          ]
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "capability_level": {
          "type": "integer",
          "enum": [0, 1, 2, 3, 4, 5],
          "description": "L0=scaffold_only, L1=import_only, L2=partial_extraction, L3=structured_mapping, L4=validated_roundtrip, L5=deterministic_edit"
        },
        "supported_resources": {
          "type": "array",
          "description": "List of .aieng resource types this adapter can produce",
          "items": {
            "type": "string",
            "enum": [
              "manifest.json",
              "geometry/source.step",
              "geometry/normalized.step",
              "geometry/topology_map.json",
              "graph/feature_graph.json",
              "graph/semantic_graph.json",
              "graph/constraints.json",
              "simulation/setup.yaml",
              "simulation/cae_mapping.json",
              "results/evidence_index.json",
              "results/claim_map.json",
              "provenance/tool_trace.json",
              "ai/summary.md"
            ]
          }
        },
        "known_limitations": {
          "type": "array",
          "description": "Explicit limitations and unknowns",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["category", "description"],
            "properties": {
              "category": {
                "type": "string",
                "enum": [
                  "geometry",
                  "topology",
                  "features",
                  "constraints",
                  "simulation_setup",
                  "mesh",
                  "results",
                  "validation",
                  "roundtrip_invariance"
                ]
              },
              "description": {
                "type": "string",
                "description": "Specific limitation or unknown"
              }
            }
          }
        },
        "notes": {
          "type": "array",
          "description": "Additional notes",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
